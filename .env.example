# Senior TV — Environment Variables
# Copy to .env and fill in values (install.sh does this automatically)

# Flask session key (auto-generated by install.sh)
SENIOR_TV_SECRET=change-me-to-a-random-string

# Server port (default 5000)
SENIOR_TV_PORT=5000

# Debug mode (0=off, 1=on)
SENIOR_TV_DEBUG=0

# Immich database password (auto-generated by install.sh, must match docker-compose.yml)
IMMICH_DB_PASSWORD=change-me

# --- Service credentials (standardized across deployments) ---

# Jellyfin — local media server (auto-configured by install.sh)
JELLYFIN_USER=seniortv
JELLYFIN_PASS=seniortv

# Immich — family photo portal (auto-configured by install.sh)
IMMICH_ADMIN_EMAIL=bstoner@gmail.com
IMMICH_ADMIN_PASS=seniortv

# Cloudflare Tunnel — remote access (get token from Cloudflare Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=

# --- Remote services (only needed if running on separate machines) ---

# Home Assistant
HA_URL=
HA_TOKEN=

# Frigate
FRIGATE_URL=
FRIGATE_CAMERAS=front_door

# Samsung TV entity in Home Assistant
HA_TV_ENTITY=

# --- Don & Colleen defaults ---
GREETING_NAMES=Colleen & Don
WEATHER_LAT=33.7083
WEATHER_LON=-117.1972
ADMIN_PASSWORD=family2026
