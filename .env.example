# Senior TV — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# install.sh auto-generates secrets and configures services.

# ─── Core ───────────────────────────────────────────────
# Flask session key (auto-generated by install.sh if blank)
SENIOR_TV_SECRET=
SENIOR_TV_PORT=5000
SENIOR_TV_DEBUG=0

# ─── Docker Services ────────────────────────────────────
# Immich database password (auto-generated by install.sh)
IMMICH_DB_PASSWORD=

# Jellyfin — local media server (auto-configured by install.sh)
JELLYFIN_USER=seniortv
JELLYFIN_PASS=seniortv

# Immich — family photo portal (auto-configured by install.sh)
IMMICH_ADMIN_EMAIL=admin@example.com
IMMICH_ADMIN_PASS=seniortv

# ─── Remote Access ──────────────────────────────────────
# Cloudflare Tunnel — get token from Cloudflare Zero Trust dashboard
# Leave blank to skip remote access setup
CLOUDFLARE_TUNNEL_TOKEN=

# ─── Smart Home (optional) ──────────────────────────────
# Home Assistant — for TV power control and automation
HA_URL=
HA_TOKEN=

# Frigate — for doorbell camera alerts
FRIGATE_URL=
FRIGATE_CAMERAS=front_door

# Samsung TV entity in Home Assistant (e.g., media_player.samsung_tv)
HA_TV_ENTITY=

# ─── Personalization ────────────────────────────────────
# Names shown in greeting (e.g., "Mom & Dad", "Grandma")
GREETING_NAMES=

# Weather location (find coordinates at https://open-meteo.com)
WEATHER_LAT=
WEATHER_LON=

# Admin panel remote access password
ADMIN_PASSWORD=family2026
