# Senior TV — Environment Variables
# Copy to .env and fill in values (install.sh does this automatically)

# Flask session key (auto-generated by install.sh)
SENIOR_TV_SECRET=change-me-to-a-random-string

# Server port (default 5000)
SENIOR_TV_PORT=5000

# Debug mode (0=off, 1=on)
SENIOR_TV_DEBUG=0

# Immich database password (auto-generated by install.sh, must match docker-compose.yml)
IMMICH_DB_PASSWORD=change-me
